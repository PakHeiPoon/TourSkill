# ─────────────────────────────────────────────────────────────────────
# TourSkill merchant-agent — environment template
# ─────────────────────────────────────────────────────────────────────
# 1. Copy this file:    cp .env.example .env
# 2. Fill in real values (see "How to get this" notes for each var)
# 3. NEVER commit .env  (it's gitignored at the repo root)
# ─────────────────────────────────────────────────────────────────────


# ─── Identity (required) ─────────────────────────────────────────────

# AGENT_ID — your ERC-8004 agent ID, assigned by IdentityRegistry.register()
# How to get: register your agent on chain. Either:
#   (a) Run `pnpm sync-card` after deploying — it'll register for you and
#       fill this value in the .env automatically.
#   (b) Call IdentityRegistry.register() yourself via cast / Foundry / etherscan,
#       grab the agentId from the AgentRegistered event.
# Leave empty until first registration; the agent boots in "draft" mode.
AGENT_ID=

# AGENT_OWNER_ADDRESS — wallet that owns this agent (display only; chain is truth)
# How to get: just the public address of your deployer wallet.
#   cast wallet address --private-key $YOUR_PRIVATE_KEY
AGENT_OWNER_ADDRESS=0x


# ─── Hosting (required) ──────────────────────────────────────────────

# PUBLIC_URL — the canonical URL where this agent serves agent-card.json
# In dev: http://localhost:8787
# In prod: your custom domain or platform-hosted URL
# Must be reachable by user-agents — they fetch /.well-known/agent-card.json
PUBLIC_URL=http://localhost:8787

# PORT — what port to listen on
PORT=8787


# ─── Storage (required) ──────────────────────────────────────────────

# STORE_DRIVER — 'sqlite' (default, single-process) or 'postgres' (multi-tenant)
STORE_DRIVER=sqlite

# STORE_URL — driver-specific connection string
#   sqlite:   file:./data/agent.db
#   postgres: postgres://user:pass@host:5432/dbname
STORE_URL=file:./data/agent.db


# ─── LLM provider (optional — only if any skill uses it) ─────────────

# LLM_PROVIDER — 'openai' | 'qiniu' | 'zerog' | 'anthropic' (any OpenAI-compat)
# Most default skills are deterministic CRUD and don't touch the LLM.
# Only set this if you use the optional concierge / nl-summary skills.
LLM_PROVIDER=qiniu

# LLM_BASE_URL — OpenAI-compatible API endpoint
#   OpenAI:    https://api.openai.com/v1
#   Qiniu:     https://api.qnaigc.com/v1
#   0G:        (resolved per-call from broker)
LLM_BASE_URL=https://api.qnaigc.com/v1

# LLM_API_KEY — API key for the LLM provider above
# How to get:
#   • Qiniu:    https://portal.qiniu.com/aitoken/key (free, ~30s)
#   • OpenAI:   https://platform.openai.com/api-keys
LLM_API_KEY=

# LLM_MODEL — which model to use
# Pick one from the provider's catalog (Qiniu: deepseek/deepseek-v3.2,
# moonshotai/kimi-k2.5, z-ai/glm-5, qwen3-max, etc.)
LLM_MODEL=deepseek/deepseek-v3.2


# ─── Chain (required for on-chain registration) ──────────────────────

# CHAIN_ID — 84532 = Base Sepolia, 8453 = Base mainnet
CHAIN_ID=84532

# RPC_URL — JSON-RPC endpoint for the chain above
#   Free public:    https://sepolia.base.org  /  https://mainnet.base.org
#   Recommended:    Alchemy/QuickNode/Infura with Base support
RPC_URL=https://sepolia.base.org

# IDENTITY_REGISTRY — ERC-8004 IdentityRegistry contract address
# Base Sepolia deployment (2026-05-06):
#   0xBdE5A55D50d2062FF5529546d8c391f6a6eEA29f
# See docs/architecture/DEPLOY_ADDRESSES.md for tx hashes + block.
IDENTITY_REGISTRY=0xBdE5A55D50d2062FF5529546d8c391f6a6eEA29f

# REPUTATION_REGISTRY — ERC-8004 ReputationRegistry contract address
# Base Sepolia deployment (2026-05-06):
#   0xcaC08083B58c7736bDf953dafeC3C3395f0D90c6
# (constructed against the dEaD escrow placeholder — Block 2 deferred)
REPUTATION_REGISTRY=0xcaC08083B58c7736bDf953dafeC3C3395f0D90c6

# BOOKING_ESCROW — Phase B: BookingEscrow contract on Base
# Leave empty for Phase A (we don't process payments yet)
BOOKING_ESCROW=

# USDC_ADDRESS — Base Sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
#                Base mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e


# ─── Payout (Phase B) ────────────────────────────────────────────────

# PAYOUT_ADDRESS — where USDC settles after escrow release
# Default: same wallet as AGENT_OWNER_ADDRESS. Override if you want
# settlement in a different wallet (e.g., a treasury multisig).
PAYOUT_ADDRESS=


# ─── Multi-tenant (platform-hosted only) ─────────────────────────────

# TENANT_ID — set by TourSkill platform runtime; leave empty for self-host
TENANT_ID=


# ─── On-chain registration (sync-card) ───────────────────────────────

# SYNC_PRIVATE_KEY — owner-wallet private key used by `pnpm sync-card`
# to broadcast register/update transactions to IdentityRegistry.
#
# How to get this:
#   • Generate a NEW testnet wallet — never reuse a mainnet key here.
#       cast wallet new
#     Output gives you (address, private key). Use the address as
#     AGENT_OWNER_ADDRESS, the private key here.
#   • Fund it with Base Sepolia ETH from the Coinbase faucet:
#       https://www.coinbase.com/faucets/base-ethereum-sepolia-faucet
#   • For mainnet: do NOT put a key in .env. Use a hardware wallet —
#     run `cast wallet import` and call register() via cast send manually
#     instead of using `pnpm sync-card`.
#
# Leave empty if you only want `pnpm sync-card --dry-run` (offline hash check).
SYNC_PRIVATE_KEY=

# AGENT_CARD_URI — public URL on-chain clients use to fetch the card.
# Defaults to `${PUBLIC_URL}/.well-known/agent-card.json`.
# Override if you serve the card from a CDN / IPFS gateway.
AGENT_CARD_URI=
